{
  "$schema": "https://ai-secure-configs.example/schemas/google-gemini/safety-settings.json",
  "_comment": "MODERATE Gemini safety settings. Balanced content filtering with reasonable limits. Use for standard enterprise development teams.",

  "safety_settings": [
    {
      "category": "HARM_CATEGORY_HARASSMENT",
      "threshold": "BLOCK_MEDIUM_AND_ABOVE"
    },
    {
      "category": "HARM_CATEGORY_HATE_SPEECH",
      "threshold": "BLOCK_MEDIUM_AND_ABOVE"
    },
    {
      "category": "HARM_CATEGORY_SEXUALLY_EXPLICIT",
      "threshold": "BLOCK_MEDIUM_AND_ABOVE"
    },
    {
      "category": "HARM_CATEGORY_DANGEROUS_CONTENT",
      "threshold": "BLOCK_MEDIUM_AND_ABOVE"
    }
  ],

  "generation_config": {
    "max_output_tokens": 4096,
    "temperature": 0.7,
    "top_p": 0.95,
    "top_k": 40
  },

  "application_layer_checks": {
    "pre_request": {
      "pii_scan": true,
      "pii_categories_to_block": [
        "ssn", "credit_card", "bank_account", "passport_number"
      ],
      "profanity_filter": true,
      "input_length_limit_chars": 100000
    },
    "post_response": {
      "output_validation": true,
      "pii_redaction": true,
      "content_moderation": true
    }
  },

  "quota_overrides": {
    "gemini_api_requests_per_minute": 100,
    "gemini_code_assist_requests_per_minute": 60
  }
}
