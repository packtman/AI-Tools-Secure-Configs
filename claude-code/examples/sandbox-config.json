{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Sandbox configuration for Claude Code. Add to managed-settings.json or settings.json. Sandboxing provides OS-level filesystem and network isolation for Bash commands.",

  "sandbox": {
    "enabled": true,

    "autoAllowBashIfSandboxed": true,

    "allowUnsandboxedCommands": false,

    "failIfUnavailable": true,

    "excludedCommands": [
      "docker *"
    ],

    "filesystem": {
      "allowWrite": [
        ".",
        "/tmp/build-output",
        "~/.cache/pip",
        "~/.npm/_cacache"
      ],

      "denyWrite": [
        "~/",
        "//etc/",
        "//var/",
        "//usr/",
        "//bin/",
        "//sbin/"
      ],

      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gcloud",
        "~/.azure",
        "~/.gnupg",
        "~/.kube/config",
        "~/.docker/config.json",
        "~/.npmrc",
        "~/.pypirc",
        "~/.netrc",
        "~/.git-credentials",
        "//etc/shadow",
        "//etc/sudoers",
        "//etc/ssl/private"
      ],

      "allowRead": [
        ".",
        "//usr/lib",
        "//usr/share",
        "//etc/ssl/certs"
      ],

      "allowManagedReadPathsOnly": false
    },

    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "github.com",
        "api.github.com",
        "objects.githubusercontent.com",
        "crates.io",
        "static.crates.io",
        "proxy.golang.org",
        "sum.golang.org"
      ],

      "deniedDomains": [
        "*.onion",
        "pastebin.com",
        "transfer.sh",
        "ngrok.io",
        "*.ngrok-free.app"
      ],

      "allowManagedDomainsOnly": false
    }
  }
}
