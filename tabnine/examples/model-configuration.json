{
  "$schema": "https://ai-secure-configs.example/schemas/tabnine/model-configuration.json",
  "_comment": "Private LLM endpoint configuration for Tabnine Enterprise. Configure via the Admin Console → Models.",

  "private_endpoints": [
    {
      "name": "azure-openai-prod",
      "provider": "azure",
      "endpoint": "https://your-resource.openai.azure.com",
      "api_version": "2024-06-01",
      "deployment_name": "gpt-4o",
      "authentication": {
        "type": "api_key",
        "key_source": "secrets_manager",
        "key_reference": "AZURE_OPENAI_API_KEY"
      },
      "settings": {
        "max_tokens": 4096,
        "temperature": 0.3,
        "timeout_seconds": 30
      }
    },
    {
      "name": "bedrock-prod",
      "provider": "amazon_bedrock",
      "region": "us-east-1",
      "model_id": "anthropic.claude-3-sonnet-20240229-v1:0",
      "authentication": {
        "type": "iam_role",
        "role_arn": "arn:aws:iam::ACCOUNT_ID:role/TabnineBedrock"
      },
      "settings": {
        "max_tokens": 4096,
        "temperature": 0.3,
        "timeout_seconds": 30
      }
    }
  ],

  "model_access_policy": {
    "allow_tabnine_hosted": false,
    "allow_private_only": true,
    "approved_models": [
      "azure-openai-prod",
      "bedrock-prod"
    ]
  }
}
