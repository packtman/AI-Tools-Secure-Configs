{
  "$schema": "https://ai-secure-configs.example/schemas/tabnine/command-permissions.json",
  "_comment": "BASELINE Tabnine command permissions. Common dev commands auto-approved. Only destructive and infrastructure commands restricted. Suitable for startups and individual developers.",

  "default_permission": "auto-approve",

  "command_categories": {
    "git": "auto-approve",
    "npm": "auto-approve",
    "yarn": "auto-approve",
    "pip": "auto-approve",
    "docker": "require-confirmation",
    "kubectl": "require-confirmation",
    "terraform": "require-confirmation",
    "aws": "require-confirmation",
    "gcloud": "require-confirmation",
    "az": "require-confirmation"
  },

  "individual_commands": {
    "auto-approve": [
      "git status",
      "git diff",
      "git log",
      "git branch",
      "git stash list",
      "git add",
      "git commit",
      "git push",
      "git pull",
      "git checkout",
      "ls",
      "cat",
      "head",
      "tail",
      "grep",
      "find",
      "wc",
      "pwd",
      "echo",
      "which",
      "npm test",
      "npm run lint",
      "npm run build",
      "npm install",
      "npx tsc --noEmit",
      "python -m pytest",
      "pip install",
      "go test ./...",
      "cargo test",
      "cargo build",
      "make test",
      "make build"
    ],

    "require-confirmation": [
      "git merge",
      "git rebase",
      "docker build",
      "docker run",
      "kubectl apply",
      "kubectl delete",
      "terraform plan",
      "terraform apply"
    ],

    "disabled": [
      "rm -rf",
      "sudo",
      "chmod 777",
      "curl | bash",
      "curl | sh",
      "wget | bash",
      "wget | sh",
      "eval",
      "exec",
      "terraform destroy",
      "docker system prune -a"
    ]
  }
}
